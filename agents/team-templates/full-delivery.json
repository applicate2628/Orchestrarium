{
  "name": "full-delivery",
  "description": "Full delivery from intake to release — roadmap → research → design → plan → implement → QA → review",
  "when": "New feature or substantial change requiring end-to-end delivery pipeline",
  "roles": [
    { "agentType": "product-manager", "stage": "intake", "whenNeeded": "scope/priority unclear" },
    { "agentType": "product-analyst", "stage": "research", "whenNeeded": "product context unclear" },
    { "agentType": "analyst", "stage": "research", "required": true },
    { "agentType": "architect", "stage": "design", "required": true },
    { "agentType": "ux-designer", "stage": "design", "whenNeeded": "user-facing work" },
    { "agentType": "algorithm-scientist", "stage": "design", "whenNeeded": "algorithmically sensitive" },
    { "agentType": "computational-scientist", "stage": "design", "whenNeeded": "scientific/numerical work" },
    { "agentType": "security-engineer", "stage": "design", "whenNeeded": "security risk exists" },
    { "agentType": "performance-engineer", "stage": "design", "whenNeeded": "performance budget matters" },
    { "agentType": "reliability-engineer", "stage": "design", "whenNeeded": "operability/recovery matters" },
    { "agentType": "planner", "stage": "plan", "required": true },
    { "agentType": "backend-engineer", "stage": "implement", "whenNeeded": "server/API/persistence work" },
    { "agentType": "frontend-engineer", "stage": "implement", "whenNeeded": "client/UI/browser work" },
    { "agentType": "qa-engineer", "stage": "QA", "required": true },
    { "agentType": "ui-test-engineer", "stage": "QA", "whenNeeded": "Qt UI regressions" },
    { "agentType": "architecture-reviewer", "stage": "review", "whenNeeded": "extensibility/maintainability critical" },
    { "agentType": "performance-reviewer", "stage": "review", "whenNeeded": "hard budget or SLA" },
    { "agentType": "security-reviewer", "stage": "review", "whenNeeded": "security risk exists" },
    { "agentType": "ux-reviewer", "stage": "review", "whenNeeded": "user-facing quality" },
    { "agentType": "accessibility-reviewer", "stage": "review", "whenNeeded": "keyboard/AT exposure" }
  ],
  "requiredRoles": ["analyst", "architect", "planner", "qa-engineer"],
  "minRoles": 4,
  "notes": "Lead selects implementation specialists (backend/frontend/qt/data/etc) based on approved phase plan. Not all optional roles fire for every task."
}
